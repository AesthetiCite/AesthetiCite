# Veridoc environment variables (example)
# Put real values in Replit Secrets (not in this file).

ENV=dev
APP_NAME=Veridoc

# Database
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME

# Admin key (set in Replit Secrets)
ADMIN_API_KEY=change-me

# Auth
REQUIRE_AUTH_FOR_ASK=true
JWT_SECRET=change-me
JWT_ALG=HS256
JWT_EXPIRES_MIN=10080   # 7 days

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# RAG / limits
MIN_CITATIONS_REQUIRED=1
MAX_CONTEXT_CHARS=12000
CHUNK_SIZE_CHARS=1200
CHUNK_OVERLAP_CHARS=200

# Rate limits
RATE_LIMIT_ASK=60/minute
RATE_LIMIT_INGEST=10/hour
