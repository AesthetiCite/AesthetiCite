modules = ["nodejs-20", "web", "python-3.11", "python3", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["cargo", "freetype", "glibcLocales", "gumbo", "harfbuzz", "hnswlib", "jbig2dec", "lcms2", "libiconv", "libimagequant", "libjpeg", "libjpeg_turbo", "libtiff", "libwebp", "libxcrypt", "mupdf", "openjpeg", "openssl", "pkg-config", "postgresql", "rustc", "swig", "tcl", "tk", "xcbuild", "xcodebuild", "zlib", "postgresql_16"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "vm"
run = ["bash", "start.sh"]
build = ["bash", "-c", "npm run build && uv sync --frozen --no-dev"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
integrations = ["javascript_openai_ai_integrations:2.0.0", "sendgrid:1.0.0"]

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "support@aestheticite.com"
SMTP_FROM = "support@aestheticite.com"
APP_PUBLIC_URL = "https://aestheticite.com"
PARTNER_PREVIEW_TOKEN = "aestheticite_partner_2026"
PREVIEW_TTL_SECONDS = "604800"
UNPAYWALL_EMAIL = "youssef.lidary@gmail.com"
AESTHETICITE_PGVECTOR_ENABLED = "1"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
